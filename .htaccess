<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Force HTTPS (required for secure PWA installation)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Transparently route all traffic to the public/ folder
    # We use REDIRECT_STATUS check to completely prevent infinite redirect loops on shared hosting!
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
